<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Visitor Sign In</title>

  <style>
    * {
      box-sizing: border-box;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
    }

    body {
      margin: 0;
      height: 100vh;
      background: #f4f6f8;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .container {
      text-align: center;
      width: 90%;
      max-width: 600px;
    }

    h1 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
      color: #2c3e50;
    }

    .button {
      display: block;
      width: 100%;
      padding: 2.5rem;
      margin: 1.5rem 0;
      font-size: 2rem;
      font-weight: bold;
      border-radius: 16px;
      text-decoration: none;
      color: white;
      transition: transform 0.1s ease, box-shadow 0.1s ease;
    }

    .sign-in {
      background-color: #0078d4;
    }

    .sign-out {
      background-color: #444;
    }

    .button:active {
      transform: scale(0.97);
      box-shadow: 0 0 0 rgba(0,0,0,0);
    }
  </style>
</head>

<body>
  <div class="container">
    <h1>Visitor Check‑In</h1>

    <!-- Replace with your Sign In form link -->
    <a class="button sign-in" href="https://forms.office.com/Pages/ResponsePage.aspx?id=KNeh0xlqoUujJKYQlBSKiawKi05lWTZMtl4lHmgYgXJUMDRGRU9MUEozTkhYV01EU082RFhPS1lXTi4u">
      Sign In
    </a>

    <!-- Replace with your Sign Out form link -->
    <a class="button sign-out" href="https://forms.office.com/Pages/ResponsePage.aspx?id=KNeh0xlqoUujJKYQlBSKiawKi05lWTZMtl4lHmgYgXJUMDVYVFhNNkJBSUYwMVhBOEw3RTdOQjk1Mi4u">
      Sign Out
    </a>
  </div>
</body>
</html>
